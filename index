
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TEST ORTAMI | Albion Radar V3.1</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    <style>
        body { background-color: #0f172a; color: #cbd5e1; }
        .glass-panel { background: rgba(30, 41, 59, 0.7); backdrop-filter: blur(10px); border: 1px solid #334155; }
        input[type="file"]::file-selector-button {
            background-color: #334155; color: white; border: none; padding: 0.5rem 1rem;
            border-radius: 0.25rem; cursor: pointer; margin-right: 1rem; transition: background-color 0.2s;
        }
        input[type="file"]::file-selector-button:hover { background-color: #475569; }
        select { color-scheme: dark; }
        option { background-color: #1e293b; color: white; }
        /* Test ortamı olduğunu belli eden kırmızı uyarı şeridi */
        .dev-banner { background-color: #b91c1c; color: white; text-align: center; font-size: 0.75rem; padding: 0.25rem; font-weight: bold; letter-spacing: 1px;}
    </style>
</head>
<body class="font-sans">

    <div class="dev-banner">⚠️ STAGING / TEST ORTAMI - BURAYA GİRİLEN VERİLER CANLI SİSTEMİ ETKİLEMEZ ⚠️</div>

    <input type="file" id="hidden-image-input" accept="image/*" class="hidden" onchange="handleImageUpdate(event)">

    <div class="max-w-5xl mx-auto p-4 md:p-8">
        <header class="mb-8 text-center">
            <h1 class="text-3xl font-bold text-amber-500 mb-2">🧪 Albion Objective Tracker (Test)</h1>
            <p class="text-sm text-slate-400 flex flex-col">
                <span>Geliştirme ve Deneme Sürümü</span>
            </p>
        </header>

        <div class="glass-panel p-6 rounded-xl mb-8 shadow-lg border-t-4 border-t-blue-500">
            <h2 class="text-xl font-semibold mb-4 text-white flex flex-col">
                <span>Yeni Objektif Ekle</span>
                <span class="text-xs text-slate-400 font-normal mt-1">Add New Objective</span>
            </h2>
            <form id="add-form" class="grid grid-cols-1 md:grid-cols-5 gap-4 items-start">
                
                <div>
                    <label class="block mb-1">
                        <span class="text-xs text-slate-300">Objektif Türü</span>
                        <span class="block text-[10px] text-slate-500">Objective Type</span>
                    </label>
                    <select id="isim" required class="w-full bg-slate-800 border border-slate-600 rounded p-2 text-white focus:border-amber-500 outline-none cursor-pointer">
                        <option value="" disabled selected>Seçiniz / Select</option>
                        <optgroup label="Sandıklar / Chests">
                            <option value="Altın Sandık / Gold Chest">Altın Sandık (Gold)</option>
                            <option value="Gümüş Sandık / Silver Chest">Gümüş Sandık (Silver)</option>
                            <option value="Bronz Sandık / Bronze Chest">Bronz Sandık (Bronze)</option>
                        </optgroup>
                        <optgroup label="Dünya Etkinlikleri / World Events">
                            <option value="Power Core">Power Core</option>
                            <option value="Energy Vortex">Energy Vortex</option>
                            <option value="Castle / Kale">Castle</option>
                            <option value="Outpost">Outpost</option>
                        </optgroup>
                        <optgroup label="Yaratıklar / Mobs">
                            <option value="World Boss">World Boss</option>
                            <option value="Resource Boss">Resource Boss</option>
                            <option value="Spider / Örümcek">Crystal Spider</option>
                        </optgroup>
                    </select>
                </div>

                <div>
                    <label class="block mb-1">
                        <span class="text-xs text-slate-300">Harita Konumu</span>
                        <span class="block text-[10px] text-slate-500">Black Zone Map</span>
                    </label>
                    <select id="harita" required class="w-full bg-slate-800 border border-slate-600 rounded p-2 text-white focus:border-amber-500 outline-none cursor-pointer">
                        <option value="" disabled selected>BZ Haritası Seç / Select BZ</option>
                        <optgroup label="🏆 Tier 8 Zones">
                            <option value="Sunfang Wasteland">Sunfang Wasteland</option>
                            <option value="Deathreach Priory">Deathreach Priory</option>
                            <option value="Glacierfall Fissure">Glacierfall Fissure</option>
                            <option value="Twinchannel Narrows">Twinchannel Narrows</option>
                            <option value="Munten Tundra">Munten Tundra</option>
                            <option value="GraveofEternity">Grave of Eternity</option>
                        </optgroup>
                        <optgroup label="⚔️ Tier 7 Zones">
                            <option value="Whitengorge">Whitengorge</option>
                            <option value="Everwinter Expanse">Everwinter Expanse</option>
                            <option value="Highstone Mound">Highstone Mound</option>
                            <option value="Wailing Bulwark">Wailing Bulwark</option>
                            <option value="Slakesands Mesa">Slakesands Mesa</option>
                        </optgroup>
                        <optgroup label="⛺ The Rests (Güvenli Bölgeler)">
                            <option value="Arthur's Rest">Arthur's Rest</option>
                            <option value="Merlyn's Rest">Merlyn's Rest</option>
                            <option value="Morgana's Rest">Morgana's Rest</option>
                        </optgroup>
                        <optgroup label="🌌 Özel Black Zone / Diğer">
                            <option value="Avalonian Road (BZ)">Avalonian Road (BZ)</option>
                            <option value="Brecilien / Mists">Brecilien / Mists</option>
                            <option value="Diğer BZ Haritası / Other BZ">Diğer BZ Haritası / Other BZ</option>
                        </optgroup>
                    </select>
                </div>

                <div>
                    <label class="block mb-1">
                        <span class="text-xs text-slate-300">Kalan Süre (Dakika)</span>
                        <span class="block text-[10px] text-slate-500">Minutes Left</span>
                    </label>
                    <input type="number" id="dakika" placeholder="Örn: 45" required min="1" class="w-full bg-slate-800 border border-slate-600 rounded p-2 text-white focus:border-amber-500 outline-none">
                </div>
                <div>
                    <label class="block mb-1">
                        <span class="text-xs text-slate-300">Görsel (İsteğe Bağlı)</span>
                        <span class="block text-[10px] text-slate-500">Image (Optional)</span>
                    </label>
                    <input type="file" id="resim" accept="image/*" class="w-full text-sm text-slate-400 file:mr-4 file:py-2 file:px-4 file:rounded file:border-0 file:text-sm file:font-semibold file:bg-slate-700 file:text-white hover:file:bg-slate-600 cursor-pointer">
                </div>
                <div class="h-full flex items-end">
                    <button type="submit" id="submit-btn" class="w-full bg-amber-600 hover:bg-amber-500 text-white font-bold py-2 px-4 rounded transition-colors flex flex-col justify-center items-center h-[42px]">
                        <span class="leading-none">Sisteme İşle</span>
                        <span class="text-[10px] font-normal opacity-80 mt-1 leading-none">Submit</span>
                    </button>
                </div>
            </form>
        </div>

        <div class="glass-panel p-6 rounded-xl shadow-lg">
            <h2 class="text-xl font-semibold mb-4 text-white flex justify-between items-start">
                <div class="flex flex-col">
                    <span>Aktif Taktiksel Hedefler</span>
                    <span class="text-xs text-slate-400 font-normal mt-1">Active Tactical Objectives</span>
                </div>
                <div class="flex flex-col items-end">
                    <span id="status" class="text-xs px-2 py-1 bg-green-900/50 text-green-400 rounded-full border border-green-800">Test Bağlantısı Aktif</span>
                </div>
            </h2>
            
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="border-b border-slate-700 text-slate-300 text-sm">
                            <th class="p-3"><div>Görsel</div><div class="text-[10px] text-slate-500 font-normal">Image</div></th>
                            <th class="p-3"><div>Tür</div><div class="text-[10px] text-slate-500 font-normal">Type</div></th>
                            <th class="p-3"><div>Harita</div><div class="text-[10px] text-slate-500 font-normal">Zone</div></th>
                            <th class="p-3"><div>Kalan Zaman</div><div class="text-[10px] text-slate-500 font-normal">Time Left</div></th>
                            <th class="p-3 text-right"><div>İşlem</div><div class="text-[10px] text-slate-500 font-normal">Action</div></th>
                        </tr>
                    </thead>
                    <tbody id="targets-body">
                        <tr><td colspan="5" class="text-center p-4 text-slate-500">Yükleniyor...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <script>
        // DİKKAT: Eğer yeni bir Supabase projesi açtıysan buradaki URL ve KEY değişmelidir!
        const SUPABASE_URL = 'https://wbrpssjxzfxiyhwibked.supabase.co';
        const SUPABASE_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6IndicnBzc2p4emZ4aXlod2lia2VkIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzUzOTA1NTAsImV4cCI6MjA5MDk2NjU1MH0.-ZOimu7lyVwG5OLyJvooCiZqvuqz523QkWHZyGV8ztA';
        const supabaseClient = supabase.createClient(SUPABASE_URL, SUPABASE_KEY);

        // İŞTE DEĞİŞİKLİK BURADA: Artık test tablona kayıt yapacak
        const TABLO_ADI = 'albion_content_tracker_deneme';
        const BUCKET_ADI = 'hedef-resimleri';

        let targets = [];
        let currentUpdateId = null;

        async function fetchTargets() {
            const { data, error } = await supabaseClient.from(TABLO_ADI).select('*').order('bitis_zamani', { ascending: true });
            if (error) { console.error('Hata:', error); return; }
            targets = data;
            renderTargets();
        }

        document.getElementById('add-form').addEventListener('submit', async (e) => {
            e.preventDefault();
            const btn = document.getElementById('submit-btn');
            btn.innerHTML = '<span class="leading-none">Yükleniyor...</span><span class="text-[10px] mt-1 leading-none">Loading...</span>';
            btn.disabled = true;

            const isim = document.getElementById('isim').value;
            const harita = document.getElementById('harita').value;
            const dakika = parseInt(document.getElementById('dakika').value);
            const resimDosyasi = document.getElementById('resim').files[0];
            const bitisZamani = new Date(Date.now() + dakika * 60000).toISOString();
            let resimUrl = null;

            try {
                if (resimDosyasi) {
                    const dosyaUzantisi = resimDosyasi.name.split('.').pop();
                    const benzersizIsim = `${Date.now()}-${Math.random().toString(36).substring(2)}.${dosyaUzantisi}`;
                    const { error: uploadError } = await supabaseClient.storage.from(BUCKET_ADI).upload(benzersizIsim, resimDosyasi);
                    if (uploadError) throw uploadError;
                    const { data: publicUrlData } = supabaseClient.storage.from(BUCKET_ADI).getPublicUrl(benzersizIsim);
                    resimUrl = publicUrlData.publicUrl;
                }

                const { error: dbError } = await supabaseClient.from(TABLO_ADI).insert([{ 
                    isim: isim, harita: harita, bitis_zamani: bitisZamani, resim_url: resimUrl 
                }]);
                if (dbError) throw dbError;

                document.getElementById('add-form').reset();
                fetchTargets(); 
            } catch (error) {
                alert("Hata oluştu / Error occurred");
            } finally {
                btn.innerHTML = '<span class="leading-none">Sisteme İşle</span><span class="text-[10px] font-normal opacity-80 mt-1 leading-none">Submit</span>';
                btn.disabled = false;
            }
        });

        function triggerImageUpdate(id) {
            currentUpdateId = id; 
            document.getElementById('hidden-image-input').click(); 
        }

        async function handleImageUpdate(event) {
            const resimDosyasi = event.target.files[0];
            if (!resimDosyasi || !currentUpdateId) return;

            const updateBtn = document.getElementById(`update-btn-${currentUpdateId}`);
            if(updateBtn) updateBtn.innerHTML = '<span class="text-[10px]">Yükleniyor...</span>';

            try {
                const dosyaUzantisi = resimDosyasi.name.split('.').pop();
                const benzersizIsim = `${Date.now()}-${Math.random().toString(36).substring(2)}.${dosyaUzantisi}`;
                
                const { error: uploadError } = await supabaseClient.storage.from(BUCKET_ADI).upload(benzersizIsim, resimDosyasi);
                if (uploadError) throw uploadError;
                
                const { data: publicUrlData } = supabaseClient.storage.from(BUCKET_ADI).getPublicUrl(benzersizIsim);
                const yeniResimUrl = publicUrlData.publicUrl;

                const { error: updateError } = await supabaseClient.from(TABLO_ADI).update({ resim_url: yeniResimUrl }).eq('id', currentUpdateId);
                if (updateError) throw updateError;

            } catch (error) {
                console.error("Güncelleme Hatası:", error);
                alert("Görsel güncellenirken hata oluştu / Error updating image!");
            } finally {
                event.target.value = '';
                currentUpdateId = null;
            }
        }

        async function deleteTarget(id) {
            await supabaseClient.from(TABLO_ADI).delete().eq('id', id);
            fetchTargets();
        }

        function formatTimeLeft(endTimeStr) {
            const end = new Date(endTimeStr).getTime();
            const now = new Date().getTime();
            const distance = end - now;

            if (distance < 0) return `<div class="flex flex-col"><span class="text-red-500 font-bold tracking-wider leading-none">SÜRE BİTTİ!</span><span class="text-[10px] text-red-400 font-normal mt-1">EXPIRED!</span></div>`;

            const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
            const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
            const seconds = Math.floor((distance % (1000 * 60)) / 1000);

            let result = "";
            if(hours > 0) result += `${hours}sa `;
            result += `${minutes}dk ${seconds}sn`;
            
            let engResult = "";
            if(hours > 0) engResult += `${hours}h `;
            engResult += `${minutes}m ${seconds}s`;

            return `<div class="flex flex-col"><span class="text-amber-400 font-mono font-bold leading-none">${result}</span><span class="text-[10px] text-amber-600/80 font-mono font-normal mt-1">${engResult}</span></div>`;
        }

        function renderTargets() {
            const tbody = document.getElementById('targets-body');
            tbody.innerHTML = '';

            if (targets.length === 0) {
                tbody.innerHTML = '<tr><td colspan="5" class="text-center p-4 text-slate-500"><div>Şu an takip edilen bir objektif yok.</div><div class="text-xs mt-1">No active objectives being tracked right now.</div></td></tr>';
                return;
            }

            targets.forEach(target => {
                const tr = document.createElement('tr');
                tr.className = 'border-b border-slate-700/50 hover:bg-slate-800/50 transition-colors';
                
                const resimHtml = target.resim_url 
                    ? `<a href="${target.resim_url}" target="_blank" title="Büyütmek için tıkla / Click to enlarge"><img src="${target.resim_url}" class="w-12 h-12 object-cover rounded border border-slate-600 hover:border-amber-500 transition-colors"></a>`
                    : `<div class="w-12 h-12 flex flex-col items-center justify-center bg-slate-800 rounded border border-slate-700 text-center leading-tight"><span class="text-[9px] text-slate-400">Görsel Yok</span></div>`;

                tr.innerHTML = `
                    <td class="p-3">${resimHtml}</td>
                    <td class="p-3 font-semibold text-white">${target.isim}</td>
                    <td class="p-3 text-slate-300">${target.harita}</td>
                    <td class="p-3" id="timer-${target.id}">${formatTimeLeft(target.bitis_zamani)}</td>
                    <td class="p-3 text-right">
                        <div class="flex justify-end gap-2">
                            <button id="update-btn-${target.id}" onclick="triggerImageUpdate(${target.id})" class="inline-flex flex-col items-center bg-blue-900/50 text-blue-400 hover:bg-blue-600 hover:text-white px-3 py-1.5 rounded transition-colors w-16">
                                <span class="text-xs font-medium leading-none">📷 Görsel</span>
                                <span class="text-[9px] font-normal opacity-80 mt-1 leading-none">Image</span>
                            </button>

                            <button onclick="deleteTarget(${target.id})" class="inline-flex flex-col items-center bg-red-900/50 text-red-400 hover:bg-red-600 hover:text-white px-3 py-1.5 rounded transition-colors w-16">
                                <span class="text-xs font-medium leading-none">Temizle</span>
                                <span class="text-[9px] font-normal opacity-80 mt-1 leading-none">Clear</span>
                            </button>
                        </div>
                    </td>
                `;
                tbody.appendChild(tr);
            });
        }

        setInterval(() => {
            targets.forEach(target => {
                const timerEl = document.getElementById(`timer-${target.id}`);
                if (timerEl) timerEl.innerHTML = formatTimeLeft(target.bitis_zamani);
            });
        }, 1000);

        supabaseClient.channel('custom-all-channel')
            .on('postgres_changes', { event: '*', schema: 'public', table: TABLO_ADI }, (payload) => {
                fetchTargets(); 
            }).subscribe();

        fetchTargets();
    </script>
</body>
</html>
